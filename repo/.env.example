# Shared
NODE_ENV=development

# Database (PostgreSQL)
POSTGRES_DB=culinary_studio
POSTGRES_USER=culinary_user
POSTGRES_PASSWORD=culinary_password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_SECURE=false
AUTH_LOCK_MAX_ATTEMPTS=10
AUTH_LOCK_DURATION_MINUTES=15
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=60
SIGNED_REQUEST_SECRET=change_me_signed_request_secret
SIGNED_REQUEST_KEY_ID=default
SIGNED_REQUEST_MAX_SKEW_SECONDS=300
SIGNED_REQUEST_NONCE_TTL_SECONDS=600
IDEMPOTENCY_KEY_TTL_HOURS=24
IDEMPOTENCY_IN_PROGRESS_TIMEOUT_SECONDS=30
SECURITY_ACTION_PATH_PREFIXES=/bookings,/billing,/invoices,/payments
BOOKING_OPEN_HOURS_NON_MEMBER=72
BOOKING_MEMBER_EARLY_ACCESS_HOURS=24
SALES_TAX_RATE=0.08875
INVOICE_DUE_DAYS=14
DATABASE_URL=postgresql://culinary_user:culinary_password@postgres:5432/culinary_studio?schema=public
REDIS_URL=redis://redis:6379

# Frontend
FRONTEND_PORT=5173
PUBLIC_API_BASE_URL=http://backend:4000
